# Copiar este archivo a .env (no se sube al repo).
# Ambas variables son opcionales: el proyecto funciona sin ninguna, en modo mock.

# Si se define, el servicio usa Claude real para la extracción en vez del modo mock.
ANTHROPIC_API_KEY=

# Ruta del archivo SQLite. Por defecto: extraccion.db en la raíz del proyecto.
DB_PATH=extraccion.db
